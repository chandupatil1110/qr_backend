PORT=3000
NODE_ENV=development

# Must match a real PostgreSQL user/password. If you see
# "password authentication failed for user ...", this URL is wrong.
#
# Easiest local setup (from backend folder):
#   docker compose up -d
#   npm run migrate
#
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emergency_alert

JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Razorpay test keys — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx

# Public base URL used in generated QR links (no trailing slash)
PUBLIC_APP_URL=http://localhost:3000

# Local dev only: skip Razorpay signature check (never enable in production)
# ALLOW_FAKE_PAYMENT=true

# Exotel (demo — mock used if unset)
EXOTEL_SID=rentocameraservices1
EXOTEL_TOKEN=5f1db32896f41156033f919fdef8f9e008be9c394eb494a7
EXOTEL_CALLER_ID=your_exotel_virtual_number

# Admin API key — required to reach the /api/admin/* endpoints and to sign
# into the /admin dashboard. If this is unset, the whole admin UI refuses
# to authorize anyone (safe default). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=change-this-to-a-long-random-string
